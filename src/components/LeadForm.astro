---
type Props = {
  id?: string;
  title?: string;
  compact?: boolean;
};

const {
  id = "lead-form",
  title = "Demander une démo",
  compact = false,
} = Astro.props;
---

<form
  id={id}
  class="lead-form w-full scroll-mt-28 rounded-lg border border-sky-line bg-white p-5 shadow-[0_20px_60px_rgba(7,20,47,0.12)] sm:p-6"
  novalidate
>
  <div class="mb-5">
    <p class="text-sm font-semibold uppercase tracking-[0.12em] text-mint-600">Démo personnalisée</p>
    <h2 class="mt-2 text-2xl font-bold text-navy-950">{title}</h2>
    <p class="mt-2 text-sm leading-6 text-ink-700">
      Un conseiller vous recontacte pour évaluer vos besoins et vous présenter l’offre adaptée.
    </p>
  </div>

  <div class={`grid gap-4 ${compact ? "" : "sm:grid-cols-2"}`}>
    <div>
      <label for={`${id}-firstName`} class="text-sm font-semibold text-ink-900">Prénom</label>
      <input
        id={`${id}-firstName`}
        name="firstName"
        type="text"
        autocomplete="given-name"
        required
        class="mt-2 w-full rounded-lg border border-sky-line bg-white px-3 py-3 text-base text-ink-900 shadow-sm transition focus:border-mint-500 focus:outline-none focus:ring-4 focus:ring-mint-500/15"
      />
    </div>
    <div>
      <label for={`${id}-lastName`} class="text-sm font-semibold text-ink-900">Nom</label>
      <input
        id={`${id}-lastName`}
        name="lastName"
        type="text"
        autocomplete="family-name"
        required
        class="mt-2 w-full rounded-lg border border-sky-line bg-white px-3 py-3 text-base text-ink-900 shadow-sm transition focus:border-mint-500 focus:outline-none focus:ring-4 focus:ring-mint-500/15"
      />
    </div>
    <div>
      <label for={`${id}-email`} class="text-sm font-semibold text-ink-900">Email professionnel</label>
      <input
        id={`${id}-email`}
        name="email"
        type="email"
        autocomplete="email"
        required
        class="mt-2 w-full rounded-lg border border-sky-line bg-white px-3 py-3 text-base text-ink-900 shadow-sm transition focus:border-mint-500 focus:outline-none focus:ring-4 focus:ring-mint-500/15"
      />
    </div>
    <div>
      <label for={`${id}-phone`} class="text-sm font-semibold text-ink-900">Téléphone</label>
      <input
        id={`${id}-phone`}
        name="phone"
        type="tel"
        autocomplete="tel"
        required
        class="mt-2 w-full rounded-lg border border-sky-line bg-white px-3 py-3 text-base text-ink-900 shadow-sm transition focus:border-mint-500 focus:outline-none focus:ring-4 focus:ring-mint-500/15"
      />
    </div>
    <div>
      <label for={`${id}-company`} class="text-sm font-semibold text-ink-900">Entreprise</label>
      <input
        id={`${id}-company`}
        name="company"
        type="text"
        autocomplete="organization"
        required
        class="mt-2 w-full rounded-lg border border-sky-line bg-white px-3 py-3 text-base text-ink-900 shadow-sm transition focus:border-mint-500 focus:outline-none focus:ring-4 focus:ring-mint-500/15"
      />
    </div>
    <div>
      <label for={`${id}-employeeCount`} class="text-sm font-semibold text-ink-900">Nombre de salariés</label>
      <select
        id={`${id}-employeeCount`}
        name="employeeCount"
        required
        class="mt-2 w-full rounded-lg border border-sky-line bg-white px-3 py-3 text-base text-ink-900 shadow-sm transition focus:border-mint-500 focus:outline-none focus:ring-4 focus:ring-mint-500/15"
      >
        <option value="">Sélectionner</option>
        <option value="1-10">1 à 10</option>
        <option value="11-25">11 à 25</option>
        <option value="26-49">26 à 49</option>
        <option value="50+">50 et plus</option>
      </select>
    </div>
    <div class={compact ? "" : "sm:col-span-2"}>
      <label for={`${id}-mainNeed`} class="text-sm font-semibold text-ink-900">Besoin principal</label>
      <select
        id={`${id}-mainNeed`}
        name="mainNeed"
        required
        class="mt-2 w-full rounded-lg border border-sky-line bg-white px-3 py-3 text-base text-ink-900 shadow-sm transition focus:border-mint-500 focus:outline-none focus:ring-4 focus:ring-mint-500/15"
      >
        <option value="">Sélectionner</option>
        <option value="Ameliorer le pouvoir d'achat">Améliorer le pouvoir d'achat</option>
        <option value="Fideliser les salaries">Fidéliser les salariés</option>
        <option value="Proposer un CE sans gestion">Proposer un CE sans gestion</option>
        <option value="Attirer / recruter">Attirer / recruter</option>
        <option value="Autre">Autre</option>
      </select>
    </div>
  </div>

  <div class="absolute -left-[9999px] top-auto h-px w-px overflow-hidden" aria-hidden="true">
    <label for={`${id}-website`}>Site web</label>
    <input id={`${id}-website`} name="website" type="text" tabindex="-1" autocomplete="off" />
  </div>

  <input type="hidden" name="utm_source" />
  <input type="hidden" name="utm_medium" />
  <input type="hidden" name="utm_campaign" />
  <input type="hidden" name="utm_content" />
  <input type="hidden" name="utm_term" />
  <input type="hidden" name="gclid" />
  <input type="hidden" name="landing_page" />
  <input type="hidden" name="audience" value="ce_pme" />
  <input type="hidden" name="brand" value="hello_boost" />
  <input type="hidden" name="page_url" />
  <input type="hidden" name="referrer" />

  <label class="mt-5 flex gap-3 text-sm leading-6 text-ink-700">
    <input
      name="consent"
      type="checkbox"
      required
      class="mt-1 h-4 w-4 shrink-0 rounded border-sky-line text-mint-600 focus:ring-mint-500"
    />
    <span>
      En envoyant ce formulaire, vous acceptez d’être recontacté au sujet de votre demande.
      Vos données sont utilisées uniquement dans le cadre du suivi commercial.
    </span>
  </label>

  <p class="mt-3 text-xs leading-5 text-ink-500">
    Protection anti-spam active. Aucun usage publicitaire externe n’est réalisé depuis ce formulaire.
  </p>

  <p class="mt-4 hidden rounded-lg border px-4 py-3 text-sm" data-form-message aria-live="polite"></p>

  <button
    type="submit"
    class="mt-5 inline-flex w-full items-center justify-center rounded-lg bg-orange-500 px-5 py-3.5 text-base font-bold text-white shadow-[0_12px_30px_rgba(245,138,61,0.35)] transition hover:bg-orange-500/90 focus:outline-none focus:ring-4 focus:ring-orange-500/25 disabled:cursor-wait disabled:opacity-70"
  >
    Demander une démo
  </button>
</form>

<script>
  import { pushDataLayer } from "../lib/tracking";
  import { hydrateAttributionFields } from "../lib/utm";

  const forms = document.querySelectorAll<HTMLFormElement>(".lead-form");

  forms.forEach((form) => {
    if (form.dataset.formBound === "true") {
      return;
    }

    form.dataset.formBound = "true";
    hydrateAttributionFields(form);

    const submitButton = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const message = form.querySelector<HTMLElement>("[data-form-message]");
    let hasStarted = false;

    form.addEventListener("focusin", (event) => {
      const target = event.target as HTMLInputElement | HTMLSelectElement | null;
      if (!hasStarted && target?.name && target.name !== "website") {
        hasStarted = true;
        pushDataLayer("form_start", {
          form_id: form.id,
          form_name: "hello_boost_ce_pme",
        });
      }
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      hydrateAttributionFields(form);

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());
      payload.consent = formData.get("consent") ? "true" : "false";

      if (submitButton) {
        submitButton.disabled = true;
          submitButton.textContent = "Envoi en cours...";
      }

      if (message) {
        message.className = "mt-4 hidden rounded-lg border px-4 py-3 text-sm";
        message.textContent = "";
      }

      try {
        const response = await fetch("/api/submit-lead", {
          method: "POST",
          credentials: "same-origin",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        const result = (await response.json()) as {
          success?: boolean;
          message?: string;
          errors?: Record<string, string>;
        };

        if (!response.ok || !result.success) {
          throw new Error(result.message || Object.values(result.errors || {})[0] || "Une erreur est survenue.");
        }

        pushDataLayer("form_submit_success", {
          form_id: form.id,
          form_name: "hello_boost_ce_pme",
          audience: "ce_pme",
        });

        window.location.assign("/merci");
      } catch (error) {
        const errorMessage = error instanceof Error ? error.message : "Une erreur est survenue. Merci de réessayer.";

        if (message) {
          message.className = "mt-4 rounded-lg border border-orange-500/30 bg-orange-500/10 px-4 py-3 text-sm text-navy-950";
          message.textContent = errorMessage;
        }

        pushDataLayer("form_submit_error", {
          form_id: form.id,
          form_name: "hello_boost_ce_pme",
          error_message: errorMessage,
        });
      } finally {
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = "Demander une démo";
        }
      }
    });
  });
</script>
