---
const benefits = [
  "Améliorer le pouvoir d’achat",
  "Fidéliser les salariés",
  "Renforcer l’attractivité employeur",
  "Proposer un avantage concret sans complexité",
  "Valoriser l’entreprise auprès des équipes",
];
---

<section class="brand-gradient-soft py-16 text-white sm:py-20">
  <div class="container-page">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-bold uppercase tracking-[0.12em] text-white/75">Une vraie valeur</p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
        Un levier RH concret
      </h2>
      <p class="mt-5 text-lg leading-8 text-white/90">
        Hello Boost n’est pas une simple liste de réductions : c’est un avantage employeur qui
        aide vos salariés et renforce votre marque interne.
      </p>
    </div>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
      {
        benefits.map((benefit, index) => (
          <article class="rounded-[28px] border border-white/18 bg-white/12 p-5 text-center backdrop-blur-sm">
            <p class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-white text-sm font-extrabold text-[#b9058a]">
              {index + 1}
            </p>
            <h3 class="mt-4 text-lg font-bold leading-snug">{benefit}</h3>
          </article>
        ))
      }
    </div>
  </div>
</section>
