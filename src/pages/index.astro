---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Hello Boost | Avantages salariés et CE pour TPE/PME"
  description="Offrez les avantages d’un comité d’entreprise à vos salariés sans gestion interne."
  canonicalPath="/"
>
  <main class="min-h-screen bg-white px-6 py-16 text-center">
    <h1 class="text-2xl font-extrabold text-navy-950">Redirection vers Hello Boost</h1>
    <p class="mt-4 text-ink-700">Vous allez être redirigé vers la landing page.</p>
    <a
      href="/ce-pme"
      class="mt-8 inline-flex rounded-full bg-orange-500 px-6 py-3 font-bold text-white"
    >
      Accéder à la landing page
    </a>
  </main>
  <script is:inline>
    window.location.replace("/ce-pme");
  </script>
</BaseLayout>
